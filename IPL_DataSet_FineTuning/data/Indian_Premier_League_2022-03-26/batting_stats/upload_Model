from huggingface_hub import HfApi, create_repo, upload_folder
from pathlib import Path

def upload_lora_model_to_hf(
    local_model_path: str,
    repo_name: str,
    hf_token: str,
    private: bool = True
):
    """
    Upload your fine-tuned LoRA model to HuggingFace Hub
    
    Args:
        local_model_path: Path to your saved model (e.g., "./ipl_cricket_lora")
        repo_name: Name for your HF repo (e.g., "ipl-cricket-lora")
        hf_token: Your HuggingFace token (from https://huggingface.co/settings/tokens)
        private: Whether to make repo private (True recommended for proprietary data)
    """
    
    api = HfApi()
    
    # Get your username
    user_info = api.whoami(token=hf_token)
    username = user_info['name']
    
    # Full repository ID
    repo_id = f"{username}/{repo_name}"
    
    print(f"Creating repository: {repo_id}")
    print(f"Privacy: {'Private' if private else 'Public'}")
    
    try:
        # Step 1: Create repository
        create_repo(
            repo_id=repo_id,
            token=hf_token,
            private=private,
            repo_type="model",
            exist_ok=True  # Won't error if repo already exists
        )
        print(f"✅ Repository created/verified: https://huggingface.co/{repo_id}")
        
        # Step 2: Upload all files from local directory
        print(f"\nUploading files from {local_model_path}...")
        upload_folder(
            folder_path=local_model_path,
            repo_id=repo_id,
            token=hf_token,
            commit_message="Upload IPL Cricket LoRA fine-tuned model"
        )
        
        print(f"\n✅ SUCCESS! Model uploaded to: https://huggingface.co/{repo_id}")
        print(f"\n📝 To use this model later:")
        print(f"   from peft import PeftModel")
        print(f"   model = PeftModel.from_pretrained(base_model, '{repo_id}')")
        
        return repo_id
        
    except Exception as e:
        print(f"❌ Error: {e}")
        return None


